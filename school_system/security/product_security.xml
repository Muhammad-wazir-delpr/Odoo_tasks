<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_company_rule" model="ir.rule">
        <field name="name">Product Template Company Rule</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="domain_force">
            ['|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids)
            ]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="product_product_company_rule" model="ir.rule">
        <field name="name">Product Variant Company Rule</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="domain_force">
            ['|',
            ('company_id', '=', False),
            ('company_id', 'in', company_ids)
            ]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>