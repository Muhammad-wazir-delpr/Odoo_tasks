<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="sale_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-esc="doc.partner_id.name"/>
                    <t t-foreach="doc.order_line" t-as="line">
                        <p>
                            <t t-esc="line.product_template_id.name"/>
                        </p>
                    </t>
                </t>
            </t>
        </t>
    </template>

    <record id="sale_report_temp" model="ir.actions.report">
        <field name="name">sale pdf</field>
        <field name="model">sale.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">qweb_reports.sale_report_template</field>
        <field name="report_file">qweb_reports.sale_report_template</field>
        <field name="print_report_name">'pdf-report'</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_type">report</field>
    </record>
</odoo>

