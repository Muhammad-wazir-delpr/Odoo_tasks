<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         IMPORT PATIENTS WIZARD
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="import_patient_wizard_view_form" model="ir.ui.view">
        <field name="name">import.patient.wizard.form</field>
        <field name="model">import.patient.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Patients from CSV">
                <sheet>
                    <div class="oe_title">
                        <h1>📥 Import Patients</h1>
                    </div>
                    <group>
                        <group string="Upload File">
                            <field name="csv_file"
                                   filename="csv_filename"
                                   widget="binary"
                                   required="not csv_file"
                            />
                            <field name="csv_filename" invisible="1"/>
                        </group>
                        <group string="Instructions">
                            <div class="alert alert-info" role="alert" style="margin:8px 0;">
                                <strong>Required CSV columns:</strong><br/>
                                <code>name, gender, phone, blood_group</code><br/><br/>
                                <ul style="margin:0; padding-left:18px;">
                                    <li><b>gender</b> must be <code>male</code> or <code>female</code></li>
                                    <li>Rows with duplicate phone numbers are skipped</li>
                                    <li>First row must be the header</li>
                                </ul>
                            </div>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import_patients"
                            string="Import Patients"
                            type="object"
                            class="btn-primary"
                            icon="fa-upload"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server action → opens wizard from Patients list toolbar -->
    <record id="action_import_patient_wizard" model="ir.actions.act_window">
        <field name="name">Import Patients</field>
        <field name="res_model">import.patient.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="import_patient_wizard_view_form"/>
        <field name="target">new</field>
    </record>

    <!-- Button on Patient list view -->
    <record id="action_import_patients_server" model="ir.actions.server">
        <field name="name">Import Patients from CSV</field>
        <field name="model_id" ref="model_hospital_patient"/>
        <field name="binding_model_id" ref="model_hospital_patient"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Import Patients',
    'res_model': 'import.patient.wizard',
    'view_mode': 'form',
    'target': 'new',
}
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         EXPORT BILLS WIZARD
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="export_bill_wizard_view_form" model="ir.ui.view">
        <field name="name">export.bill.wizard.form</field>
        <field name="model">export.bill.wizard</field>
        <field name="arch" type="xml">
            <form string="Export Bills to Excel">
                <sheet>
                    <div class="oe_title">
                        <h1>📤 Export Bills to Excel</h1>
                    </div>
                    <group string="Filter by Appointment Date (optional)">
                        <group>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group string="Download" invisible="not excel_file">
                        <field name="excel_file"
                               filename="excel_filename"
                               widget="binary"
                               readonly="1"/>
                        <field name="excel_filename" invisible="1"/>
                    </group>
                    <div class="alert alert-info" role="alert" style="margin:8px 0;">
                        Exported columns:
                        <b>Appointment ID · Patient Name · Consultation Fee ·
                           Medicine Charges · Total Amount</b>
                    </div>
                </sheet>
                <footer>
                    <button name="action_export_bills"
                            string="Export to Excel"
                            type="object"
                            class="btn-primary"
                            icon="fa-file-excel-o"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_export_bill_wizard" model="ir.actions.act_window">
        <field name="name">Export Bills</field>
        <field name="res_model">export.bill.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="export_bill_wizard_view_form"/>
        <field name="target">new</field>
    </record>

    <!-- Server action binding on Bills list -->
    <record id="action_export_bills_server" model="ir.actions.server">
        <field name="name">Export Bills to Excel</field>
        <field name="model_id" ref="model_hospital_bill"/>
        <field name="binding_model_id" ref="model_hospital_bill"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Export Bills',
    'res_model': 'export.bill.wizard',
    'view_mode': 'form',
    'target': 'new',
}
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         MENU ITEMS
    ══════════════════════════════════════════════════════════════════════ -->

    <menuitem id="menu_import_export"
              name="Import / Export"
              parent="hospital_management.hospital_management_parent"
              sequence="50"/>


    <menuitem id="menu_import_patients"
              name="Import Patients"
              parent="menu_import_export"
              action="action_import_patient_wizard"
              sequence="10"/>

    <menuitem id="menu_export_bills"
              name="Export Bills"
              parent="menu_import_export"
              action="action_export_bill_wizard"
              sequence="20"/>

</odoo>
