<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="appointment_wizard_form_view" model="ir.ui.view">
            <field name="name">Appointment_Wizard form</field>
            <field name="model">appointment.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <group>
                            <field name="patient_id"/>
                            <field name="doctor_id"/>
                            <field name="appointment_date"/>
                            <field name="symptoms"/>
                        </group>
                    </group>

                    <footer>
                        <button name="action_create_appointment" string="Create" type="object"
                                class="btn-primary"/>

                        <button string="Cancel" special="cancel" class="btn-primary"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_appointment_wizard" model="ir.actions.act_window">
            <field name="name">Quick Appointment</field>
            <field name="res_model">appointment.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>