<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Category -->

    <record id="module_category_hospital_management" model="ir.module.category">
        <field name="name">Hospital Management</field>
        <field name="description">Helps you manage hospital operations.</field>
        <field name="sequence">10</field>
    </record>

    <!-- Groups -->

    <record id="group_receptionist" model="res.groups">
        <field name="name">Receptionist</field>
        <field name="category_id" ref="hospital_management.module_category_hospital_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="category_id" ref="hospital_management.module_category_hospital_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="hospital_management.module_category_hospital_management"/>
        <field name="implied_ids" eval="[(4, ref('hospital_management.group_receptionist')), (4, ref('hospital_management.group_doctor'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->

    <record id="appointment_doctor_rule" model="ir.rule">
        <field name="name">Doctor Own Appointments</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="groups" eval="[(4, ref('hospital_management.group_doctor'))]"/>
        <field name="domain_force">
            [('doctor_id.user_id', '=', user.id)]
        </field>
    </record>

    <record id="appointment_manager_rule" model="ir.rule">
        <field name="name">Manager All Appointments</field>
        <field name="model_id" ref="model_hospital_appointment"/>
        <field name="groups" eval="[(4, ref('hospital_management.group_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>