<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="hospital_appointment_tree_view" model="ir.ui.view">
            <field name="name">Hospital_Appointment tree</field>
            <field name="model">hospital.appointment</field>
            <field name="arch" type="xml">
                <list>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="appointment_date"/>
                    <field name="symptoms"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="hospital_appointment_form_view" model="ir.ui.view">
            <field name="name">Hospital_Appointment form</field>
            <field name="model">hospital.appointment</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" id="button_confirm" string="Confirm" class="btn-primary"
                                type="object" invisible="state != 'draft'"/>

                        <button name="action_complete" id="button_complete" string="Complete" class="btn-warning"
                                type="object" invisible="state != 'confirmed'"/>

                        <button name="action_cancel" id="button_cancel" string="Cancel" class="btn-success"
                                type="object" invisible="state not in ('draft', 'confirmed')"/>

                        <button name="action_send_appointment_email" string="Send Email" class="btn-info"
                                type="object"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancelled"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="patient_id"/>
                                <field name="doctor_id"/>
                                <field name="appointment_date"/>
                                <field name="symptoms"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Prescriptions">
                                <field name="prescription_ids">
                                    <list>
                                        <field name="medicine"/>
                                        <field name="dosage"/>
                                        <field name="instructions"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="hospital_appointment_search_view" model="ir.ui.view">
            <field name="name">Hospital_Appointment search</field>
            <field name="model">hospital.appointment</field>
            <field name="arch" type="xml">
                <search>
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="state"/>

                    <filter name="today_appointments" string="Today Appointments" domain="[
                        ('appointment_date', '&gt;=', context_today().strftime('%%Y-%%m-%%d 00:00:00')),
                        ('appointment_date', '&lt;=', context_today().strftime('%%Y-%%m-%%d 23:59:59'))]"/>

                    <filter name="confirmed_appointments" string="Confirmed" domain="[('state','=','confirmed')]"/>
                    <filter name="done_appointments" string="Done" domain="[('state','=','done')]"/>

                    <group expand="1" string="Group By">
                        <filter string="Doctor" name="doctor_id" context="{'group_by':'doctor_id'}"/>
                        <filter string="State" name="state" context="{'group_by':'state'}"/>
                        <filter string="Date" name="appointment_date" context="{'group_by':'appointment_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_hospital_appointment" model="ir.actions.act_window">
            <field name="name">Hospital Appointment</field>
            <field name="res_model">hospital.appointment</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="hospital_appointment_parent"
                  name="Appointment"
                  action="action_hospital_appointment"
                  parent="hospital_patient"/>
    </data>
</odoo>