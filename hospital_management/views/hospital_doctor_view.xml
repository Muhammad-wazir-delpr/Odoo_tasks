<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="hospital_doctor_tree_view" model="ir.ui.view">
            <field name="name">Hospital_Doctor.tree</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="specialization"/>
                    <field name="phone"/>
                    <field name="consultation_fee"/>
                </list>
            </field>
        </record>

        <record id="hospital_doctor_form_view" model="ir.ui.view">
            <field name="name">Hospital_Doctor.form</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div name="button_box" class="oe_button_box">
                            <button name="action_view_appointments"
                                    class="oe_stat_button"
                                    icon="fa-calendar"
                                    type="object">

                                <field name="appointment_count" widget="statinfo" string="Appointments"/>
                            </button>
                        </div>

                        <group>
                            <group>
                                <field name="name"/>
                                <field name="specialization"/>
                                <field name="phone"/>
                                <field name="email"/>
                                <field name="experience"/>
                                <field name="consultation_fee"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Appointments">
                                <field name="appointment_ids">
                                    <list>
                                        <field name="patient_id"/>
                                        <field name="appointment_date"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="hospital_doctor_search_view" model="ir.ui.view">
            <field name="name">Hospital_Doctor Search</field>
            <field name="model">hospital.doctor</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="specialization"/>
                </search>
            </field>
        </record>

        <record id="action_hospital_doctor" model="ir.actions.act_window">
            <field name="name">Hospital Doctor</field>
            <field name="res_model">hospital.doctor</field>
            <field name="view_mode">list,form</field>
        </record>


        <menuitem id="hospital_doctor_sub"
                  name="Doctors"
                  parent="hospital_patient"
                  action="action_hospital_doctor"/>
    </data>
</odoo>