<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!-- Kanban View -->
        <record id="hospital_dashboard_kanban_view" model="ir.ui.view">
            <field name="name">hospital.dashboard.kanban</field>
            <field name="model">hospital.dashboard</field>
            <field name="arch" type="xml">
                <kanban create="false" class="o_kanban_dashboard" banner_route="/hospital_management/dashboard_banner">
                    <field name="patient_id"/>
                    <field name="doctor_id"/>
                    <field name="appointment_date"/>
                    <field name="total_amount"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click card mb-3" style="border-left: 5px solid #4f46e5; border-radius: 8px; padding: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: all 0.2s ease;">
                                <div class="oe_kanban_details">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong class="o_kanban_record_title" style="font-size: 15px; color: #1e293b;">
                                            <field name="patient_id"/>
                                        </strong>
                                        <span class="badge badge-pill badge-primary" style="background-color: #e0e7ff; color: #4338ca; font-size: 11px; padding: 4px 8px;">
                                            <field name="doctor_id"/>
                                        </span>
                                    </div>
                                    <div style="color: #64748b; font-size: 13px;">
                                        <div class="mb-1">
                                            <i class="fa fa-calendar mr-1"/> <field name="appointment_date"/>
                                        </div>
                                        <div>
                                            <i class="fa fa-money mr-1"/> Fee: <strong style="color: #0f172a;"><field name="total_amount"/></strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Graph View -->
        <record id="hospital_dashboard_graph_view" model="ir.ui.view">
            <field name="name">hospital.dashboard.graph</field>
            <field name="model">hospital.dashboard</field>
            <field name="arch" type="xml">
                <graph string="Revenue by Doctor" type="bar">
                    <field name="doctor_id" type="row"/>
                    <field name="revenue" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Pivot View -->
        <record id="hospital_dashboard_pivot_view" model="ir.ui.view">
            <field name="name">hospital.dashboard.pivot</field>
            <field name="model">hospital.dashboard</field>
            <field name="arch" type="xml">
                <pivot string="Billing Analysis">
                    <field name="appointment_date" type="row" interval="month"/>
                    <field name="doctor_id" type="col"/>
                    <field name="total_amount" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Action -->
        <record id="action_hospital_dashboard" model="ir.actions.act_window">
            <field name="name">Dashboard</field>
            <field name="res_model">hospital.dashboard</field>
            <field name="view_mode">kanban,graph,pivot</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Welcome to the Hospital Dashboard!
                </p>
                <p>
                    Here you can view patient statistics, appointments, and billing summaries.
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="hospital_dashboard_menu"
                  name="Dashboard"
                  parent="hospital_prescription_parent"
                  action="action_hospital_dashboard"
                  sequence="1"/>
    </data>
</odoo>
