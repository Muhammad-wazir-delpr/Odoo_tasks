<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ══════════════════════════════════════════════════════════════
             Cron 1 — Appointment Reminder
             Fires every hour and notifies patients whose appointment
             is within the next 24 hours.
        ══════════════════════════════════════════════════════════════ -->
        <record id="ir_cron_appointment_reminder" model="ir.cron">
            <field name="name">Hospital: Send Appointment Reminders</field>
            <field name="model_id" ref="model_hospital_appointment"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_appointment_reminders()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════
             Cron 2 — Auto-Cancel Missed Appointments
             Fires once a day and cancels any draft/confirmed appointment
             whose appointment_date has already passed.
        ══════════════════════════════════════════════════════════════ -->
        <record id="ir_cron_auto_cancel_appointments" model="ir.cron">
            <field name="name">Hospital: Auto-Cancel Missed Appointments</field>
            <field name="model_id" ref="model_hospital_appointment"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_cancel_missed_appointments()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
