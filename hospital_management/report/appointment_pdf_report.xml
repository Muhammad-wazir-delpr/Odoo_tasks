<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_hospital_appointment_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h3>
                            Patient :
                            <span style="margin-left: 20px;" t-esc="doc.patient_id.name"/>
                        </h3>
                        <h4>
                            Doctor :
                            <span style="margin-left: 20px;" t-esc="doc.doctor_id.name"/>
                        </h4>
                        <h5>
                            Appointment Date :
                            <span style="margin-left: 20px;" t-esc="doc.appointment_date"/>
                        </h5>

                        <h5>
                            Symptoms :
                            <span style="margin-left: 20px;" t-esc="doc.symptoms"/>
                        </h5>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="report_hospital_appointment_temp" model="ir.actions.report">
        <field name="name">Appointment Slip</field>
        <field name="model">hospital.appointment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.report_hospital_appointment_template</field>
        <field name="report_file">hospital_management.report_hospital_appointment_template</field>
        <field name="print_report_name">'pdf-report'</field>
        <field name="binding_model_id" ref="hospital_management.model_hospital_appointment"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
