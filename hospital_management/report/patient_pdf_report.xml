<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="report_hospital_patient_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <t t-esc="doc.patient_id"/>
                        <br/>
                        <br/>

                        <h3>
                            Patient Name :
                            <span style="margin-left:20px;" t-esc="doc.name"/>
                        </h3>

                        <h4>
                            Gender :
                            <span style="margin-left:15px;" t-esc="doc.gender"/>
                        </h4>

                        <h5>
                            Blood Group :
                            <span style="margin-left:15px;" t-esc="doc.blood_group"/>
                        </h5>
                        <br/>
                        <h6>
                            Phone No :
                            <span style="margin-left:15px;" t-esc="doc.phone"/>
                        </h6>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="report_hospital_patient_temp" model="ir.actions.report">
        <field name="name">Patient Card</field>
        <field name="model">hospital.patient</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hospital_management.report_hospital_patient_template</field>
        <field name="report_file">hospital_management.report_hospital_patient_template</field>
        <field name="print_report_name">'pdf-report'</field>
        <field name="binding_model_id" ref="hospital_management.model_hospital_patient"/>
        <field name="binding_type">report</field>
    </record>
</odoo>